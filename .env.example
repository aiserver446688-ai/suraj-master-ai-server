# ===== REQUIRED =====
  # Gemini API Key — Get free from: https://aistudio.google.com/apikey
  GEMINI_API_KEY=your_gemini_api_key_here

  # Database — Add Railway PostgreSQL plugin, it auto-sets this
  DATABASE_URL=postgresql://user:pass@host:5432/db

  # ===== OPTIONAL =====
  NODE_ENV=production
  PORT=3000
  LOG_LEVEL=info
  